{
  "name": "agents-cli",
  "version": "0.1.0",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "bin": {
    "agents-cli": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile dist/agents-cli",
    "install-cli": "./install.sh",
    "test": "bun test src/",
    "test:integration": "INTEGRATION=1 bun test tests/integration/",
    "test:all": "INTEGRATION=1 bun test"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dockerode": "^4.0.9",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/dockerode": "^4.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
